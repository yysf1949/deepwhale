{
  "name": "@deepwhale/edit-engine",
  "version": "1.0.10",
  "description": "File editing engines: hashline + unified-diff with conflict detection",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./engines/hashline": {
      "types": "./dist/engines/hashline/index.d.ts",
      "import": "./dist/engines/hashline/index.js"
    },
    "./engines/unified-diff": {
      "types": "./dist/engines/unified-diff/index.d.ts",
      "import": "./dist/engines/unified-diff/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "deepwhale",
    "ai-agent",
    "edit",
    "hashline",
    "unified-diff",
    "patch",
    "file-editing"
  ],
  "author": {
    "name": "yysf1949",
    "email": "butterfly443@openclaw.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yysf1949/deepwhale.git",
    "directory": "packages/edit-engine"
  },
  "homepage": "https://github.com/yysf1949/deepwhale#readme",
  "bugs": {
    "url": "https://github.com/yysf1949/deepwhale/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@deepwhale/core": "^1.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist .tsbuildinfo"
  }
}
