{
  "name": "@deepwhale/core",
  "version": "1.0.12",
  "description": "Core primitives for DeepWhale: i18n, session JSONL, compaction, types",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "deepwhale",
    "ai-agent",
    "i18n",
    "session",
    "compaction",
    "jsonl",
    "deepseek",
    "anthropic"
  ],
  "author": {
    "name": "yysf1949",
    "email": "butterfly443@openclaw.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yysf1949/deepwhale.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/yysf1949/deepwhale#readme",
  "bugs": {
    "url": "https://github.com/yysf1949/deepwhale/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist .tsbuildinfo"
  }
}
