{
  "name": "@deepwhale/coding-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "deepwhale": "./bin/deepwhale.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "dependencies": {
    "@deepwhale/core": "workspace:*",
    "@deepwhale/edit-engine": "workspace:*",
    "@deepwhale/llm": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist .tsbuildinfo"
  }
}
