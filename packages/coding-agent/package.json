{
  "name": "@deepwhale/coding-agent",
  "version": "2.0.0",
  "description": "DeepWhale CLI: DeepSeek-first AI coding agent. Linear sessions, 6 tools, Docker sandbox.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "deepwhale": "./bin/deepwhale.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "deepwhale",
    "ai-agent",
    "coding-agent",
    "cli",
    "deepseek",
    "anthropic",
    "claude-code-alternative",
    "codex-clone",
    "session",
    "sandbox"
  ],
  "author": {
    "name": "yysf1949",
    "email": "butterfly443@openclaw.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yysf1949/deepwhale.git",
    "directory": "packages/coding-agent"
  },
  "homepage": "https://github.com/yysf1949/deepwhale#readme",
  "bugs": {
    "url": "https://github.com/yysf1949/deepwhale/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@deepwhale/code-intel": "^2.0.0",
    "@deepwhale/core": "^1.0.0",
    "@deepwhale/edit-engine": "^1.0.0",
    "@deepwhale/llm": "^1.0.0",
    "sql.js-fts5": "^1.4.0",
    "youtube-transcript": "^1.2.1"
  },
  "scripts": {
    "build": "tsc -b --force && node ../llm/scripts/copy-toml.mjs && node scripts/copy-tui-ink-bundle.mjs",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.11"
  }
}
